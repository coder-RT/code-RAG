# =============================================================================
# Code-RAG Root Environment Variables
# =============================================================================
# This file contains environment variables used across the entire project.
# Rename to .env for docker-compose or root-level scripts:
#   mv env.sample .env
# =============================================================================

# -----------------------------------------------------------------------------
# LLM API Keys (Required)
# -----------------------------------------------------------------------------

# OpenAI - Primary provider for embeddings and chat
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic - Alternative for Claude models
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# -----------------------------------------------------------------------------
# Docker Compose Configuration
# -----------------------------------------------------------------------------

# Ports
SERVER_PORT=8000
CLIENT_PORT=5173

# Environment
ENVIRONMENT=development

