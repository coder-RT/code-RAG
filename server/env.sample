# =============================================================================
# Code-RAG Server Environment Variables
# =============================================================================
# Rename this file to .env and fill in your values:
#   mv env.sample .env
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Provider Configuration
# -----------------------------------------------------------------------------

# OpenAI (Primary - used for embeddings and chat)
OPENAI_API_KEY=sk-your-openai-api-key-here
LLM_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# Anthropic (Alternative LLM provider)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# AWS Bedrock (Alternative - for enterprise)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# Azure OpenAI (Alternative - for enterprise)
AZURE_OPENAI_API_KEY=your-azure-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# -----------------------------------------------------------------------------
# LLM Provider Selection
# -----------------------------------------------------------------------------
# Options: openai, anthropic, bedrock, azure
LLM_PROVIDER=openai

# -----------------------------------------------------------------------------
# Vector Database Configuration
# -----------------------------------------------------------------------------

# ChromaDB (Default - local development)
CHROMA_PERSIST_DIRECTORY=./data/chroma
CHROMA_COLLECTION_NAME=codebase

# PostgreSQL + pgvector (Production alternative)
# POSTGRES_URL=postgresql://user:password@localhost:5432/coderag
# PGVECTOR_COLLECTION=codebase

# Pinecone (Cloud vector DB)
# PINECONE_API_KEY=your-pinecone-key
# PINECONE_ENVIRONMENT=us-east-1
# PINECONE_INDEX_NAME=coderag

# Qdrant (Self-hosted vector DB)
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=your-qdrant-key
# QDRANT_COLLECTION=codebase

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
DEBUG=true
LOG_LEVEL=INFO

# CORS Origins (comma-separated for multiple origins)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# -----------------------------------------------------------------------------
# RAG Configuration
# -----------------------------------------------------------------------------
MAX_FILE_SIZE_KB=500
CHUNK_SIZE=1500
CHUNK_OVERLAP=200
CONTEXT_LIMIT=5

# -----------------------------------------------------------------------------
# Agent Configuration
# -----------------------------------------------------------------------------
AGENT_MAX_ITERATIONS=10
AGENT_TEMPERATURE=0.1

# -----------------------------------------------------------------------------
# Security (Production)
# -----------------------------------------------------------------------------
# API_KEY=your-api-key-for-auth
# JWT_SECRET=your-jwt-secret-key
# ALLOWED_HOSTS=api.yourdomain.com

